{
  "manifest_version": 3,
  "name": "Jsonifier",
  "version": "1.1.0",
  "description": "Side-panel JSON viewer: paste JSON to see a collapsible, syntax-highlighted tree alongside any page.",
  "permissions": ["sidePanel", "storage"],
  "side_panel": {
    "default_path": "viewer/viewer.html"
  },
  "action": {
    "default_title": "Open Jsonifier",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
